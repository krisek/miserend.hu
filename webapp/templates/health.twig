{% set base_template = foremail ? 'layout_simpliest.twig' : 'layout.twig' %}
{% extends base_template %}


{% set columns2 = true %}
    

{% block content %}
	<style>
		.testresult-truncated {
			cursor: pointer;
			user-select: none;
		}
		.testresult-truncated.expanded {
			overflow: visible !important;
			text-overflow: clip !important;
			white-space: normal !important;
		}
	</style>
    
	<p>Az ellenőrzést kezdeményezte <a href="/user/{{ user.uid }}/edit">{{ user.login }}</a> vagyis {{ user.name }}.</p>
	
	<h3 id="variables">Változók és körülmények</h3>
	<table class="table table-hover table-condensed table-striped">
		<tr>
			<th>name</th>
			<th>value</th>
		</tr>
		{% for info in infos %}
			<tr>
				<td>{{ info.0 }}</td>
				<td>{{ info.1|striptags('<br><a>')|raw }}</td>

			</tr>
		{% endfor %}
		<tr>
			<td>githash (valószínűsíthető!)</td>
			<td><a href="https://github.com/borazslo/miserend.hu/commit/{{ githash }}">{{ githash[0:7] }}</a></td>
		</tr>
	</table>
	
	<h3 id="cronjobs">Időzített feladatok</h3>
	<p>Az időzített feladatok kézzel is futtathatóak egyesével vagy <a href="{{ base_url }}/index.php?q=cron" target="_blank">egyben itt</a>.</p>
	<p>Most: {{ "now"|date('Y-m-d H:i:s') }}</p>
	<table class="table table-hover table-condensed table-striped">
		<tr>
			<th>id</th>
			<th>class::function()</th>
			<th>frequency (from - until)</th>
			<th>deadline_at</th>
			<th>attempts</th>
			<th>lastsuccess_at</th>
		</tr>
		{% for cron in cronjobs %}
			<tr>
				<td>{{ cron.id }}</td>
				<td><a href="{{ base_url }}/index.php?q=cron&cron_id={{cron.id}}" target="_blank">{{ cron.class }}::{{ cron.function }}()</a></td>
				<td>{{ cron.frequency }} {% if cron.from %}({{ cron.from }} - {{ cron.until }}){% endif %}</td>
				<td class="{% if cron.deadline_at < "now"|date("Y-m-d H:i:s") %}table-danger{% endif %}">{{ cron.deadline_at }}</td>
				<td  style="text-align: center" class="{% if cron.attempts > 0 %}table-danger{% endif%}">{{ cron.attempts }}</td>
				<td>{{ cron.lastsuccess_at }}</td>
			</tr>
		{% endfor %}
	</table>
	
	<h3 id="elasticsearch">ElasticSearch állapot</h3>
	<p>A keresőnk az ElasticSearch szolgáltatást használja. Az alábbi táblázat az indexek állapotát mutatja.</p>
	<table class="table table-hover table-condensed table-striped">
		<tr>
			<th>health</th>
			<th>status</th>
			<th>index</th>
			
			<th>docs.count</th>
			<th>docs.deleted</th>
			<th>store.size</th>
			<th>pri.store.size</th>
		</tr>
		{% for esindex in elasticsearch %}
			<tr>
				<td>
					<span class="badge {{ esindex.health == 'green' ? 'bg-success' : (esindex.health == 'yellow' ? 'bg-warning' : (esindex.health == 'red' ? 'bg-danger' : 'bg-secondary')) }}">
						{{ esindex.health }}
					</span>
				</td>
				<td>{{ esindex.status }}</td>
				<td>{{ esindex.index }}</td>
				<td style="text-align: center">{{ attribute(esindex, 'docs.count')|number_format(0, '.', ' ') }}</td>
				<td style="text-align: center">{{ attribute(esindex, 'docs.deleted')|number_format(0, '.', ' ') }}</td>
				<td>{{ attribute(esindex, 'store.size') }}</td>
				<td>{{ attribute(esindex, 'pri.store.size') }}</td>
			</tr>
		{% endfor %}
	</table>
		
		
		

	<h3 id="externalapis">Külső szolgáltatók elérhetősége</h3>
	<p><i>Olyanok mint mapqquest, openstreetmap, kozossegekapi, liturgiativ, nominatim, openinghapi, overpass</i></p> 

	<table class="table table-hover table-striped" style="table-layout: fixed; width: 100%;">
		<tr>
			<th class="col-3">testresult</th>
			<th>name</th>
			<th class="col-1">last_month</th>
			<th class="col-1">cache</th>			
			
		</tr>
		{% for externalapi in externalapis %}
			<tr>
				<td class="text-truncate {% if externalapi.testresult != 'OK' %}table-danger{% endif %}">
					{% if externalapi.testresult == 'OK' %}
						<span class="badge bg-success">OK</span>
					{% else %}
						<span class="testresult-truncated" style="display: block; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="Click to expand">{{ externalapi.testresult }}</span>
					{% endif %}
				</td>
				<td class="text-truncate">
					<strong>{{ externalapi.name }}</strong><br/>
					<a href="{{ externalapi.apiUrl }}">{{ externalapi.apiUrl }}</a>
				</td>
				<td style="text-align: center;">{{ externalapi.stat }}</td>
				<td style="text-align: center;">{{ externalapi.cache }}</td>				
											
			</tr>
		{% endfor %}
	</table>

	<h3 id="boundaries">Területi elhelyezkedési adatok (Boundaries) állapota</h3>
	<p>Azt, hogy melyik megyében/egyházmegyében/városban/körzetben van egy templom, azt az OSM (OpenStreetMap) adatokból az overpassapi-val olvassuk ki.</p>

	<table class="table table-hover table-condensed table-striped">
		<tr>
			<td><strong>Átlagosan frissítettség</strong></td>
			<td>{{ boundariesStats.with_osm.avg_days_old }} nap</td>
		</tr>
		<tr>
			<td><strong>Legfrissebb</strong></td>
			<td>
				{% set newestDate = boundariesStats.with_osm.newest|date('Y-m-d', 'UTC') %}
				{% set now = "now"|date('Y-m-d', 'UTC') %}
				{% set newestDateTime = date(newestDate) %}
				{% set nowDateTime = date(now) %}
				{% set daysDiff = ((nowDateTime.timestamp - newestDateTime.timestamp) / 86400)|round(0, 'floor') %}
				{% if daysDiff < 7 %}
					<span class="badge bg-success">{{ boundariesStats.with_osm.newest }}</span>
				{% elseif daysDiff > 30 %}
					<span class="badge bg-danger">{{ boundariesStats.with_osm.newest }}</span>
				{% else %}
					<span class="badge">{{ boundariesStats.with_osm.newest }}</span>
				{% endif %}
			</td>
		</tr>
		<tr>
			<td><strong>Legöregebb</strong></td>
			<td>
				{% set oldestDate = boundariesStats.with_osm.oldest|date('Y-m-d', 'UTC') %}
				{% set oldestDateTime = date(oldestDate) %}
				{% set daysDiffOldest = ((nowDateTime.timestamp - oldestDateTime.timestamp) / 86400)|round(0, 'floor') %}
				{% if daysDiffOldest < 365 %}
					<span class="badge bg-success">{{ boundariesStats.with_osm.oldest }}</span>
				{% else %}
					<span class="badge bg-danger">{{ boundariesStats.with_osm.oldest }}</span>
				{% endif %}
			</td>
		</tr>
		<tr>
			<td style="width: 40%;"><strong>Orphan Boundaries</strong> (nincs templomhoz kötve)</td>
			<td>
				{% if boundariesStats.orphan_count == 0 %}
						<span class="badge bg-success">0</span>
				{% else %}
						<span class="badge bg-danger">{{ boundariesStats.orphan_count }}</span>							
				{% endif %}
			</td>
		</tr>
		<tr>
			<td colspan="2">
				<div style="display: flex; height: 40px; border-radius: 4px; overflow: hidden; background-color: #e9ecef;">
					<!-- With OSM Boundaries - Zöld -->
					<div style="width: {{ boundariesStats.churches_with_osm_percentage }}%; background-color: #28a745; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 14px;">
						{% if boundariesStats.churches_with_osm_percentage > 5 %}
							{{ boundariesStats.churches_with_osm_boundary }} ({{ boundariesStats.churches_with_osm_percentage }}%)
						{% endif %}
					</div>
					<!-- Without OSM Boundaries - Piros -->
					<div style="width: {{ boundariesStats.churches_without_osm_percentage }}%; background-color: #dc3545; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 14px;">
						{% if boundariesStats.churches_without_osm_percentage > 5 %}
							{{ boundariesStats.churches_without_osm_boundary }} ({{ boundariesStats.churches_without_osm_percentage }}%)
						{% else %}
							{{ boundariesStats.churches_without_osm_boundary }}
						{% endif %}
					</div>
				</div>
				<div style="margin-top: 8px; font-size: 12px; color: #666;">
					<span style="color: #28a745;">■</span>Templomok OSM lokációval: {{ boundariesStats.churches_with_osm_boundary }}/{{ boundariesStats.total_churches }}
					&nbsp;&nbsp;
					<span style="color: #dc3545;">■</span>Templomok OSM lokáció nélkül: {{ boundariesStats.churches_without_osm_boundary }}/{{ boundariesStats.total_churches }}
				</div>
			</td>
		</tr>
	</table>

	<h3 id="externalapis">Levelezőrendszer egészsége</h3>
	
	<table class="table table-hover table-condensed table-striped">
			<tr>
				<td>Host:Port</td><td>{{ mailing.Host }}:{{ mailing.Port }}</td>
			</tr>
			<tr>
				<td>debug level</td><td>{{ mailing.debug }}</td>
			</tr>
			<tr>				
				<td>Teszt eredmény</td>
				<td>
					{% if foremail %}
						It is the test email itself. ;)
					{% else %}
						<span class="{% if mailing.testresult != 'OK' %}table-danger{% endif%}">{{ mailing.testresult }}</span>
					{% endif %}
				</td>
			</tr>
	</table>
	
	{% if emails|length > 0 %}
		<p><i>Az elmúlt 30 napban elküldött levelek statisztikája:</i></p>
		<table class="table table-hover table-condensed table-striped">
			<tr>
				<th >type</th>
				<th >status</th>
				<th >total</th>
			</tr>
			{% for email in emails %}
				<tr>
					<td>{{ email.type }}</td>
					<td>{{ email.status }}</td>
					<td>{{ email.total }}</td>
				</tr>
			{% endfor %}
		</table>
	{% else %}
		<div class="alert alert-danger">Az elmúlt 30 napban nem volt kiküldött email.</div>
	{% endif %}

	<script>
		document.querySelectorAll('.testresult-truncated').forEach(function(element) {
			element.addEventListener('click', function(e) {
				e.stopPropagation();
				this.classList.toggle('expanded');
				this.title = this.classList.contains('expanded') ? 'Click to collapse' : 'Click to expand';
			});
		});
	</script>
{% endblock%}