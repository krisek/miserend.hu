{% set columns2 = true  %}
{% extends  "layout.twig" %}

{% import "forms.twig" as forms %}

{% set title = "Miserend feltöltése / módosítása" %}


{% block pageHeader %}
    <div class="page-header">
        <h2>            
            Miserend szerkesztése: {{ church.names.0 }}
			<div style="float:right" class="text-end">{% include "church/_adminlinks.twig" %}</div>
            {% if church.alternative_names|length > 0 %}
                <br/>
                <small>
                    <span class="hidden-xs hidden-sm">
                       {{ church.alternative_names.0|raw }}{% if church.alternative_names|length > 1 %}, <a href="#" onclick="this.style.display='none'; document.getElementById('all-names').style.display='inline'; return false;">...</a><span id="all-names" style="display:none;" onclick="document.getElementById('all-names').style.display='none'; this.previousElementSibling.style.display='inline'; return false;">
                            {{ church.alternative_names|slice(1)|join(", ")|raw }}                            
                        </span>
                    {% endif %}
                    </span>
                </small>
            {% endif %}
        </h2>
    </div>
{%  endblock %}

{% block content %}

{% if church.id in tids %}
    <div class="alert alert-danger text-center" role="alert" style="max-width:600px;margin:20px auto;font-weight:700;">
        <strong>Vigyázz — még nincs kész!</strong>
        <p>Ennek a templomnak az adatait nem sikerült a régi rendszerből még teljesen áthozni. Amíg ez nem történik meg, kérlek ne módosíts a miserend adatain.</p>
    </div>
    <div id="alertlayer" class="error" style="padding:10px;width:100%;height:100%;background-color:rgba(255,255,255,0.8);position:fixed;top:0;left:0;display:none"></div>
{% endif %}

<div class="row" style="margin-top: 20px;">
    <div class="col-md-12">
        {% set alertClass = elasticMassesCount == 0 ? 'alert-danger' : (elasticMassesCount < 50 ? 'alert-info' : 'alert-success') %}
        <div class="alert {{ alertClass }}" role="alert">
            <div style="display: flex; justify-content: space-between; align-items: center;">
                <div id="elastic-status-text">
                    A keresőnk erre az évre <strong>{{ elasticMassesCount }}</strong> eseményt talált.
                </div>
                <div>                    
                    <button class="btn btn-sm btn-outline-primary regenerate-schedule-btn" data-church-id="{{ church.id }}" title="Elasticsearch misék regenerálása">
							<i class="fas fa-sync-alt"></i>
						</button>
                </div>
            </div>
        </div>
    </div>
</div>

{% include 'angularjs.twig' %}

<script>
    document.querySelectorAll('.regenerate-schedule-btn').forEach(function(button) {
        button.addEventListener('click', function(e) {
            e.preventDefault();
            const churchId = this.dataset.churchId;
            const currentYear = new Date().getFullYear();
            const lastYear = currentYear - 1;
            const nextYear = currentYear + 1;
            
            const url = '/calendar/generate?tids[]=' + churchId + '&years[]=' + lastYear + '&years[]=' + currentYear + '&years[]=' + nextYear;
            
            fetch(url, {
                method: 'PUT'
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    alert('Elasticsearch misék sikeresen regenerálva!');
                    document.getElementById('elastic-status-text').textContent = 'Frissítse az oldalt az aktuális adatokhoz.';
                } else {
                    alert('Hiba az elasticsearch misék regenerálása során: ' + (data.message || 'Ismeretlen hiba'));
                    document.getElementById('elastic-status-text').textContent = 'Frissítse az oldalt az aktuális adatokhoz.';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                alert('Hiba az elasticsearch misék regenerálása során: ' + error.message);
                document.getElementById('elastic-status-text').textContent = 'Frissítse az oldalt az aktuális adatokhoz.';
            });
        });
    });
</script>

{% endblock %}